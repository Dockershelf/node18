Description: Include cstdint in V8 base headers
 Newer libstdc++/compiler combinations no longer expose fixed-width integer
 types transitively through the existing V8 base includes. Include cstdint
 directly in logging.h and macros.h.
Author: Dockershelf Maintainers <41898282+github-actions[bot]@users.noreply.github.com>
Forwarded: no

--- a/deps/v8/src/base/logging.h	2022-04-18 19:22:37
+++ b/deps/v8/src/base/logging.h	2026-07-05 00:25:14
@@ -8,6 +8,7 @@
 #include <cstring>
 #include <sstream>
 #include <string>
+#include <cstdint>
 
 #include "src/base/base-export.h"
 #include "src/base/build_config.h"

--- a/deps/v8/src/base/macros.h	2022-04-18 19:22:37
+++ b/deps/v8/src/base/macros.h	2026-07-05 00:25:14
@@ -7,6 +7,7 @@
 
 #include <limits>
 #include <type_traits>
+#include <cstdint>
 
 #include "src/base/compiler-specific.h"
 #include "src/base/logging.h"
